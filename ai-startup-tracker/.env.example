# === Global AI Startup Tracker ===

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/ai_startup_tracker

# GitHub API token (required - for higher rate limits)
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# --- LLM Classification ---
# Backend: "together" (recommended), "groq", or "ollama"
LLM_BACKEND=together
LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Together.ai API key (recommended - generous free tier)
# Get one at: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your-together-key-here

# Groq API key (alternative - strict rate limits on free tier)
# Get one at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-key-here

# --- Data Sources ---
# Crunchbase parquet files
CB_ORGANIZATIONS_PATH=data/organizations.parquet
CB_CATEGORIES_PATH=data/category_groups.parquet

# PitchBook parquet files
PB_DEAL_PATH=data/pitchbook_other_glob_deal.parquet
PB_RELATION_PATH=data/pitchbook_other_glob_deal_investor_relation.parquet

# --- Agentic Scraper ---
# Tavily API key for web extraction
TAVILY_API_KEY=your-tavily-key-here

# Anthropic API key for planner/extractor/validator agent loop
ANTHROPIC_API_KEY=your-anthropic-key-here
# Cheapest default: Haiku 4.5 (3.5 Haiku retired Feb 2026 — see Anthropic model deprecations)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# JS-heavy sites (React/Next SPAs): install browsers after pip — playwright install chromium
# AGENTIC_PLAYWRIGHT=0   # set to disable headless fallback
# AGENTIC_PLAYWRIGHT_WAIT_MS=4500   # ms to wait after domcontentloaded for lazy lists

# --- Optional ---
SERPAPI_API_KEY=your-serpapi-key-here
DEBUG=false
LOG_LEVEL=INFO
